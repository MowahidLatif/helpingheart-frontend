# API backend URL
VITE_API_BASE_URL=http://127.0.0.1:5050

# Stripe (donation payments)
# Temporary test key from Stripe Dashboard -> Developers -> API keys (Publishable key)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Public org sites: apex domain suffix (e.g. helpinghands.ca). Used with host client-name.helpinghands.ca → org subdomain client-name.
# VITE_PUBLIC_SITE_HOST_SUFFIX=helpinghands.ca

# Set to "true" to show the classic block page layout editor alongside the AI builder.
# VITE_ENABLE_CLASSIC_PAGE_BUILDER=true

# If true, the AI wizard requires a platform Stripe payment before generation (API must set REQUIRE_PLATFORM_PAYMENT_FOR_AI=1).
# VITE_REQUIRE_PLATFORM_PAYMENT_FOR_AI=true
